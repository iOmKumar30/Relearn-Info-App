generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model Centre {
  id               String                  @id @default(uuid())
  code             String                  @unique @db.VarChar(12)
  name             String?
  streetAddress    String?                 @map("street_address")
  city             String?
  district         String?
  state            String?
  pincode          String?                 @db.VarChar(10)
  status           CentreStatus            @default(ACTIVE)
  dateAssociated   DateTime                @map("date_associated")
  dateLeft         DateTime?               @map("date_left")
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  classrooms       Classroom[]
  facilitatorLinks FacilitatorAssignment[]

  @@index([city, state])
  @@index([status])
}

model CentreCodeCounter {
  state String @id
  seq   Int
}

model Classroom {
  id                String                       @id @default(uuid())
  code              String?                      @unique @db.VarChar(24)
  centreId          String                       @map("centre_id")
  section           SectionCode?                 @map("section_code")
  timing            ClassTiming?
  monthlyAllowance  Int?                         @map("monthly_allowance")
  status            ClassroomStatus              @default(ACTIVE)
  dateCreated       DateTime?                    @map("date_created")
  dateClosed        DateTime?                    @map("date_closed")
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  city              String?
  district          String?
  pincode           String?                      @db.VarChar(10)
  state             String?
  streetAddress     String?                      @map("street_address")
  centre            Centre                       @relation(fields: [centreId], references: [id], onDelete: Cascade)
  tutorAssignments  TutorAssignment[]
  studentHistory    StudentClassroomAssignment[]
  monthlyAttendance MonthlyClassroomAttendance[]

  @@index([centreId])
  @@index([status, section, timing])
}

model ClassroomCodeCounter {
  key String @id
  seq Int
}

model User {
  id                       String                       @id @default(uuid())
  name                     String?
  email                    String                       @unique
  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  activatedAt              DateTime?
  address                  String?
  onboardingStatus         OnboardingStatus             @default(PENDING_PROFILE)
  phone                    String?
  profileSubmittedAt       DateTime?
  roleRequestedAt          DateTime?
  status                   UserStatus                   @default(ACTIVE)
  sessionVersion           Int?                         @default(0)
  gender                   Gender?
  roleHistory              UserRoleHistory[]
  employee                 Employee?
  member                   Member?
  tutorAssignments         TutorAssignment[]
  facilitatorAssignments   FacilitatorAssignment[]
  attendanceEntered        MonthlyClassroomAttendance[] @relation("AttendanceEnteredBy")
  emailCredential          EmailCredential?
  accounts                 Account[]
  roleRequests             RoleRequest[]
  facilitatorEmployeeLinks FacilitatorEmployee[]        @relation("FacilitatorToEmployee")
  employeeFacilitatorLinks FacilitatorEmployee[]        @relation("EmployeeToFacilitator")
  trainingAttendances      TutorTrainingAttendance[]    @relation("UserToAttendance")
  boardExamResults         BoardExamResult[]            @relation("TutorToBoardResult")

  @@index([status])
  @@index([email])
  @@index([onboardingStatus])
}

model Role {
  id          String            @id @default(uuid())
  name        RoleName          @unique
  description String?
  userHistory UserRoleHistory[]
}

model UserRoleHistory {
  id        String    @id @default(uuid())
  userId    String
  roleId    String
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([userId, endDate])
  @@index([roleId])
}

model EmailCredential {
  id           String    @id @default(uuid())
  userId       String    @unique
  email        String    @unique
  passwordHash String
  passwordSalt String?
  lastLoginAt  DateTime?
  failedCount  Int       @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  providerEmail     String?
  accessToken       String?
  refreshToken      String?
  tokenType         String?
  scope             String?
  expiresAt         Int?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RoleRequest {
  id             String    @id @default(uuid())
  userId         String
  requestedRoles String
  message        String?
  status         String    @default("PENDING")
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model FacilitatorAssignment {
  id        String    @id @default(uuid())
  userId    String
  centreId  String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  centre    Centre    @relation(fields: [centreId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([centreId, startDate, endDate])
}

model FacilitatorEmployee {
  id             String   @id @default(uuid())
  facilitatorId  String
  employeeUserId String
  startDate      DateTime
  createdAt      DateTime @default(now())
  facilitator    User     @relation("FacilitatorToEmployee", fields: [facilitatorId], references: [id], onDelete: Cascade)
  employee       User     @relation("EmployeeToFacilitator", fields: [employeeUserId], references: [id], onDelete: Cascade)

  @@index([facilitatorId])
  @@index([employeeUserId])
}

model TutorAssignment {
  id           String    @id @default(uuid())
  userId       String
  classroomId  String
  startDate    DateTime
  endDate      DateTime?
  isSubstitute Boolean   @default(false)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([classroomId, startDate, endDate])
  @@index([isSubstitute])
}

model Employee {
  id          String           @id @default(uuid())
  userId      String           @unique
  designation String
  joiningDate DateTime
  status      EmploymentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Member {
  id              String              @id @default(uuid())
  userId          String              @unique
  memberType      MemberType
  joiningDate     DateTime
  leavingDate     DateTime?
  status          MemberStatus        @default(ACTIVE)
  feeAmount       Decimal?            @db.Decimal(12, 2)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  pan             String?             @db.VarChar(10)
  memberId        String?             @unique
  isGoverningBody Boolean             @default(false)
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  fees            MemberFee[]
  typeHistory     MemberTypeHistory[]

  @@index([status])
  @@index([memberType])
  @@index([isGoverningBody])
}

model MemberFee {
  id          String   @id @default(uuid())
  memberId    String
  fiscalLabel String
  paidOn      DateTime
  amount      Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, fiscalLabel])
  @@index([fiscalLabel])
}

model MemberTypeHistory {
  id         String     @id @default(cuid())
  memberId   String
  memberType MemberType
  startDate  DateTime   @default(now())
  endDate    DateTime?
  changedBy  String?
  createdAt  DateTime   @default(now())
  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
}

model Intern {
  id                   String         @id @default(cuid())
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  name                 String
  email                String?
  mobile               String?
  address              String?
  gender               Gender?
  dateOfBirth          DateTime?
  educationCompleted   String?
  institution          String?
  ongoingCourse        String?
  areasOfInterest      String?
  joiningDate          DateTime?
  completionDate       DateTime?
  preferredHoursPerDay String?
  workingMode          WorkingMode?
  associatedAfter      Boolean?       @default(false)
  comments             String?
  status               InternStatus?  @default(ACTIVE)
  feeAmount            Int?
  feePaidDate          DateTime?
  paymentStatus        PaymentStatus? @default(PENDING)
  memberId             String?        @unique
}

enum Category {
  GENERAL
  EWS
  OBC
  SC
  ST
}

enum SchoolType {
  GOVERNMENT
  PRIVATE
  GOVT_AIDED
}

model Student {
  id            String      @id @default(uuid())
  name          String
  aadhaarNo     String?     @unique(map: "student_aadhaar_unique")
  rollNo        String      @unique
  gender        Gender?
  category      Category?
  schoolName    String?
  schoolType    SchoolType?
  dob           DateTime?
  streetAddress String?     @map("street_address")
  city          String?
  district      String?
  state         String?
  pincode       String?     @db.VarChar(10)
  fatherName    String?
  motherName    String?
  parentPhone   String?
  admissionDate DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  assignments StudentClassroomAssignment[]

  boardResult BoardExamResult?

  @@index([city, state])
}

model StudentClassroomAssignment {
  id          String           @id @default(uuid())
  studentId   String
  classroomId String
  joinDate    DateTime         @map("join_date")
  leaveDate   DateTime?        @map("leave_date")
  status      AssignmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classroom   Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([classroomId, joinDate, leaveDate])
}

model BoardExamResult {
  id String @id @default(uuid())

  studentId String @unique

  passingYear   Int
  totalMarks    Float
  marksObtained Float
  grade         String
  spTutorId     String?
  spTutor       User?   @relation("TutorToBoardResult", fields: [spTutorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([passingYear])
  @@index([spTutorId])
}

model MonthlyClassroomAttendance {
  id                    String    @id @default(uuid())
  classroomId           String
  year                  Int
  month                 Int
  totalStudentsEnrolled Int?
  openDays              Int?
  totalPresent          Int?
  attendancePercentage  Decimal?  @db.Decimal(5, 2)
  registerPhotoUrl      String?   @map("register_photo_url")
  remarks               String?
  submittedAt           DateTime  @default(now())
  lastUpdatedAt         DateTime  @updatedAt
  enteredById           String?   @map("entered_by_id")
  tutorPhone            String?   @map("tutor_phone")
  classroom             Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  enteredBy             User?     @relation("AttendanceEnteredBy", fields: [enteredById], references: [id], onDelete: Restrict)

  @@unique([classroomId, year, month])
  @@index([classroomId, year])
  @@index([year, month])
  @@index([enteredById])
}

model AcademicYear {
  year      Int      @id
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Donation {
  id            String   @id @default(cuid())
  pan           String?
  name          String
  address       String
  email         String
  contact       String
  reason        String
  gstno         String   @default("N/A")
  method        String
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime
  receiptNumber String   @unique
  transactionId String   @unique

  @@index([date])
  @@index([email])
  @@map("donation")
}

model Counter {
  financialYear String @id
  seq           Int

  @@map("counter")
}

model KPI {
  id          String            @id @default(cuid())
  key         String            @unique
  label       String
  unit        KPIUnit
  description String?
  active      Boolean           @default(true)
  category    String?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  values      KPIMonthlyValue[]
  targets     KPIFiscalTarget[]
}

model KPIMonthlyValue {
  id        String         @id @default(cuid())
  kpiId     String
  month     DateTime
  value     Float
  source    KPIValueSource
  notes     String?
  userId    String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  kpi       KPI            @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, month, source])
}

model KPIFiscalTarget {
  id          String   @id @default(cuid())
  kpiId       String
  fiscalLabel String
  startDate   DateTime
  endDate     DateTime
  targetValue Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  kpi         KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, fiscalLabel])
}

model MembershipCertificate {
  id            String   @id @default(cuid())
  name          String
  year          String
  dateIssued    DateTime
  certificateNo String   @unique
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([year])
  @@index([dateIssued])
}

model ParticipationCertificate {
  id            String          @id @default(cuid())
  certificateNo String?         @unique
  name          String
  aadhaar       String?
  classYear     String?
  institute     String
  duration      String
  startDate     DateTime
  endDate       DateTime
  issueDate     DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  eventName     String?
  type          CertificateType @default(PARTICIPATION)

  @@index([name])
  @@index([aadhaar])
}

model Project {
  id             String        @id @default(uuid())
  title          String
  description    String?
  status         ProjectStatus @default(ONGOING)
  conclusion     String?
  nextSteps      String?
  mentors        String?
  sponsoredBy    String?
  year           String?
  funds          Decimal?      @db.Decimal(10, 2)
  place          String?
  targetGroup    String?
  beneficiaries  String?
  reportUrl      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  approvalUrl    String?
  proposalUrl    String?
  rating         Int?          @default(0)
  utilizationUrl String?

  @@index([status])
  @@index([year])
}

model GstReceipt {
  id            String   @id @default(uuid())
  invoiceNo     String   @unique
  invoiceDate   DateTime
  dateOfSupply  String?
  placeOfSupply String?
  reverseCharge String?  @default("N")
  billToName    String
  billToGstin   String?  @default("NA")
  billToState   String   @default("Jharkhand")
  billToCode    String?  @default("20")
  shipToName    String?
  shipToGstin   String?  @default("NA")
  shipToState   String?  @default("Jharkhand")
  shipToCode    String?  @default("20")
  items         Json?
  totalAmount   Float
  totalTax      Float
  grandTotal    Float
  amountInWords String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PaymentVoucher {
  id              String   @id @default(uuid())
  voucherNo       String   @unique
  paymentDate     DateTime
  projectName     String?
  expenditureHead String?
  payeeName       String
  payeeMobile     String?
  items           Json?
  totalAmount     Float
  amountInWords   String
  paymentMode     String?
  paymentRef      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InvoiceCounter {
  id            String @id @default(uuid())
  financialYear String @unique
  currentSeq    Int    @default(0)
}

model GlobalSequence {
  id      String @id @default("member_seq")
  current Int    @default(0)
}

model FinancialYear {
  id        String             @id @default(cuid())
  name      String             @unique
  startDate DateTime
  endDate   DateTime
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  months    MonthlyStatement[]
}

model MonthlyStatement {
  id                String        @id @default(cuid())
  month             Int
  year              Int
  dataPopulatedDate DateTime?     @default(now())
  startDate         DateTime?
  endDate           DateTime?
  startBalance      Decimal?      @db.Decimal(15, 2)
  endBalance        Decimal?      @db.Decimal(15, 2)
  statementFileUrl  String?
  financialYearId   String
  createdById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  financialYear     FinancialYear @relation(fields: [financialYearId], references: [id])
  transactions      Transaction[]

  @@unique([month, year])
  @@index([financialYearId])
}

model Transaction {
  id             String           @id @default(cuid())
  txnDate        DateTime?
  valueDate      DateTime?
  description    String?
  txnId          String?
  refNo          String?
  branchCode     String?
  type           TransactionType
  amount         Decimal?         @db.Decimal(15, 2)
  runningBalance Decimal?         @db.Decimal(15, 2)
  partyName      String?
  reason         String?
  statementId    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  statement      MonthlyStatement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  @@index([statementId])
  @@index([txnDate])
}

enum InternStatus {
  ACTIVE
  COMPLETED
  DROPPED
  PENDING_START
}

enum WorkingMode {
  ONSITE
  REMOTE
  HYBRID
}

enum PaymentStatus {
  PAID
  PENDING
  WAIVED
}

enum CertificateType {
  PARTICIPATION
  INTERNSHIP
  TRAINING
}

enum CentreStatus {
  ACTIVE
  INACTIVE
}

enum ClassroomStatus {
  ACTIVE
  INACTIVE
}

enum SectionCode {
  JR
  SR
  BOTH
}

enum ClassTiming {
  MORNING
  EVENING
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
}

enum AssignmentStatus {
  ACTIVE
  LEFT
}

enum Gender {
  M
  F
  O
}

enum RoleName {
  PENDING
  ADMIN
  TUTOR
  FACILITATOR
  RELF_EMPLOYEE
  TUTOR_OF_TUTOR
  MEMBER
}

enum OnboardingStatus {
  PENDING_PROFILE
  SUBMITTED_PROFILE
  PENDING_ROLE
  ACTIVE
  REJECTED
}

enum MemberType {
  ANNUAL
  INTERN
  HONORARY
  LIFE
  FOUNDER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum KPIValueSource {
  MANUAL
  AUTO
}

enum KPIUnit {
  COUNT
  PERCENT
  LAKHS
}

enum ProjectStatus {
  PLANNED
  ONGOING
  COMPLETED
  ON_HOLD
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum TrainingAttendanceStatus {
  ABSENT
  PRESENT
  PRESENT_RESPONDED
}

model TutorTrainingAttendance {
  id        String                   @id @default(uuid())
  classId   String                   @map("class_id")
  tutorId   String                   @map("tutor_id")
  status    TrainingAttendanceStatus
  amount    Int                      @default(0)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  class     TutorTrainingClass       @relation(fields: [classId], references: [id], onDelete: Cascade)
  tutor     User                     @relation("UserToAttendance", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([classId, tutorId])
  @@index([tutorId])
}

model TutorTrainingClass {
  id          String                    @id @default(uuid())
  yearId      Int                       @map("year_id")
  month       Int
  date        DateTime
  trainingBy  String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  year        TutorTrainingYear         @relation(fields: [yearId], references: [year], onDelete: Cascade)
  attendances TutorTrainingAttendance[]

  @@index([yearId, month])
}

model TutorTrainingYear {
  year      Int                  @id
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  classes   TutorTrainingClass[]
}

model TrainingPayoutRate {
  id               String   @id @default("default_rate") // Singleton record
  absentAmount     Int      @default(0)
  presentAmount    Int      @default(50)
  presentResponded Int      @default(75)
  updatedAt        DateTime @updatedAt
}
enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model KpiJobQueue {
  id          String    @id @default(uuid())
  targetMonth String    @db.VarChar(7) // Format: YYYY-MM
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  lastError   String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, createdAt])
  @@map("kpi_job_queue")
}